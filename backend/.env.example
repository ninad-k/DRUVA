# =============================================================================
# DHRUVA Backend — Environment Configuration (example)
# Copy this file to .env and fill in real values. Never commit .env.
# =============================================================================

# --- App --------------------------------------------------------------------
DHRUVA_ENV=development
DHRUVA_DEBUG=true
DHRUVA_LOG_LEVEL=INFO
DHRUVA_SERVICE_NAME=dhruva-backend
DHRUVA_SERVICE_VERSION=0.1.0

# --- HTTP / gRPC / WS ports -------------------------------------------------
DHRUVA_HTTP_HOST=0.0.0.0
DHRUVA_HTTP_PORT=8000
DHRUVA_GRPC_HOST=0.0.0.0
DHRUVA_GRPC_PORT=50051
DHRUVA_WS_HOST=0.0.0.0
DHRUVA_WS_PORT=8001

# --- CORS -------------------------------------------------------------------
DHRUVA_CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# --- Database ---------------------------------------------------------------
DHRUVA_DB_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/dhruva
DHRUVA_DB_POOL_SIZE=10
DHRUVA_DB_MAX_OVERFLOW=20

# --- Redis ------------------------------------------------------------------
DHRUVA_REDIS_URL=redis://localhost:6379/0

# --- JWT --------------------------------------------------------------------
DHRUVA_JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
DHRUVA_JWT_ALGORITHM=HS256
DHRUVA_JWT_ISSUER=dhruva.local
DHRUVA_JWT_AUDIENCE=dhruva-users
DHRUVA_JWT_ACCESS_TTL_SECONDS=900
DHRUVA_JWT_REFRESH_TTL_SECONDS=604800

# --- Encryption for broker credentials (AES-256-GCM) ------------------------
# Generate with: python -c "import secrets,base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
DHRUVA_MASTER_KEY=REPLACE_WITH_32_BYTE_BASE64_KEY

# --- Observability ----------------------------------------------------------
DHRUVA_OTLP_ENDPOINT=http://localhost:4317
DHRUVA_ENABLE_TRACING=true
DHRUVA_ENABLE_METRICS=true

# --- Email ------------------------------------------------------------------
DHRUVA_SMTP_HOST=smtp.example.com
DHRUVA_SMTP_PORT=587
DHRUVA_SMTP_USER=
DHRUVA_SMTP_PASSWORD=
DHRUVA_SMTP_FROM=noreply@dhruva.local

# --- Broker API keys (per-user is stored in DB encrypted; these are defaults) ---
ZERODHA_API_KEY=
ZERODHA_API_SECRET=
UPSTOX_API_KEY=
UPSTOX_API_SECRET=
DHAN_API_KEY=
DHAN_API_SECRET=
FYERS_API_KEY=
FYERS_API_SECRET=
FIVEPAISA_API_KEY=
FIVEPAISA_API_SECRET=
