# =============================================================================
# DHRUVA — repo-wide gitignore (Python + Node + Docker + IDE)
# =============================================================================

# --- Python -----------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
.pip-cache/
.eggs/
*.egg-info/
*.egg
build/
dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/
.tox/
.hypothesis/

# Auto-generated gRPC stubs
backend/app/api/grpc/_generated/

# Alembic local
backend/alembic/versions/__pycache__/

# --- Node / React -----------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
package-lock.json
yarn.lock
pnpm-lock.yaml

# Vite / build artifacts
frontend/dist/
frontend/.vite/

# Auto-generated gRPC-Web stubs
frontend/src/api/grpc/_generated/

# --- ML model artifacts -----------------------------------------------------
backend/app/strategies/ml/models/**/*.pkl
backend/app/strategies/ml/models/**/*.joblib
backend/app/strategies/ml/models/**/*.pt
backend/app/strategies/ml/models/**/*.onnx
backend/app/strategies/ml/models/**/*.bin

# --- Environment / secrets --------------------------------------------------
.env
.env.local
.env.*.local
*.env
!*.env.example
*.pfx
*.pem
*.key

# --- IDE / OS ---------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- Docker / data volumes (when bind-mounted) ------------------------------
postgres_data/
redis_data/
prometheus_data/
grafana_data/

# --- Logs / generated reports / temp ----------------------------------------
logs/
*.log
reports/
*.pdf
*.xlsx
tmp/
temp/
*.tmp
dump.rdb

# --- CI cruft ---------------------------------------------------------------
.github/workflows/*.bak

# --- Legacy .NET (retained until /backend Python port is fully replaces it) -
bin/
obj/
*.suo
*.user
*.nupkg
